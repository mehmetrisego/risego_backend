# ===========================================
# RiseGo Backend - Ortam Değişkenleri Şablonu
# ===========================================
# Bu dosyayı .env olarak kopyalayın ve değerleri doldurun:
#   cp .env.example .env
#
# .env dosyası asla GitHub'a push edilmemelidir!

# Yandex Fleet API (zorunlu)
YANDEX_CLIENT_ID=taxi/park/YOUR_PARK_ID
YANDEX_API_KEY=YOUR_API_KEY
YANDEX_PARTNER_ID=YOUR_PARK_ID

# Yandex çalışma kuralı ID (opsiyonel - yoksa API'den otomatik alınır)
# YANDEX_WORK_RULE_ID=your_work_rule_id

# Sunucu portu (opsiyonel - varsayılan: 3000)
# Railway otomatik PORT atar, local'de 3000 kullanılır
PORT=3000

# NetGSM OTP SMS API (giriş doğrulama için)
# https://www.netgsm.com.tr/dokuman/#otp-sms
NETGSM_USERNAME=YOUR_NETGSM_USERNAME
NETGSM_USERCODE=YOUR_NETGSM_USERCODE
NETGSM_MSGHEADER=RISE LTD
